{
  "project_name": "The AI Pit",
  "project_type": "nodejs",
  "bundle": "core-brand",
  "targets": [
    "web-seo"
  ],
  "sources": [
    "built_in_defaults",
    "cli_args"
  ],
  "metadata": {
    "title": "The AI Pit | Next.js AI Debate Simulator",
    "short_description": "A Next.js-based AI debate simulator using OpenRouter to orchestrate structured, moderator-led discussions between customizable AI characters on any topic.",
    "social_title": "The AI Pit: Orchestrate Structured Multi-Model AI Debates",
    "social_description": "Run custom AI showdowns with unique character profiles, moderator interventions, and streaming responses via OpenRouter. Includes built-in presets and shareable replay snapshots.",
    "keywords": [
      "next.js",
      "openrouter",
      "ai-debate",
      "llm-orchestration",
      "react",
      "typescript",
      "ai-simulator",
      "streaming-responses",
      "ai-agents"
    ]
  },
