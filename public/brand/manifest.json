{
  "project_name": "aipit",
  "project_type": "nodejs",
  "bundle": "core-brand",
  "targets": [
    "web-seo"
  ],
  "sources": [
    "built_in_defaults",
    "cli_args"
  ],
  "metadata": {
    "title": "aipit | AI-Driven Debate Platform",
    "short_description": "A Next.js application for running structured, multi-round debates between customizable AI characters using OpenRouter, featuring automated moderation and shareable replays.",
    "social_title": "aipit: AI Character Debates with Automated Moderation",
    "social_description": "Build, watch, and share structured debates between AI personalities. Features multi-model support, character presets, and immutable replay snapshots.",
    "keywords": [
      "nextjs",
      "openrouter",
      "ai-debate",
      "llm-orchestration",
      "structured-output",
      "ai-characters",
      "typescript",
      "tailwind-css",
      "ai-agents"
    ]
  },
  "assets": [
    {
      "key": "logo",
      "kind": "logo",
      "target": "shared",
      "strategy": "generated",
      "path": "logo/logo-1024.png",
      "size": [
        1024,
        1024
      ]
    },
    {
      "key": "icon",
      "kind": "icon",
      "target": "shared",
      "strategy": "generated_from_logo_reference",
      "path": "icon/icon-1024.png",
      "size": [
        1024,
        1024
      ]
    },
    {
      "key": "web-seo-favicon-16",
      "kind": "favicon",
      "target": "web-seo",
      "strategy": "resized_from_icon",
      "path": "web-seo/favicon/favicon-16.png",
      "size": [
        16,
