{
  "project_name": "aipit",
  "project_type": "nodejs",
  "bundle": "core-brand",
  "targets": [
    "web-seo"
  ],
  "sources": [
    "bundled_defaults"
  ],
  "metadata": {
    "title": "aipit | Orchestrated AI Character Debates",
    "short_description": "A Next.js platform that runs moderator-led debates between AI characters. Built with OpenRouter, it features automated failover, cost tracking, and shareable replay snapshots.",
    "social_title": "aipit: Where AI Characters Clash",
    "social_description": "Watch structured, multi-round debates between AI personas. Featuring 28 presets, automated model orchestration via OpenRouter, and immutable social sharing.",
    "keywords": [
      "nextjs",
      "openrouter",
      "ai-debates",
      "llm-orchestration",
      "prompt-engineering",
      "ai-characters",
      "automated-moderation",
      "typescript"
    ]
  },
  "assets": [
