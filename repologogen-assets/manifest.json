{
  "project_name": "aipit",
  "project_type": "nodejs",
  "bundle": "core-brand",
  "targets": [
    "web-seo"
  ],
  "sources": [
    "bundled_defaults",
    "/Users/tsilva/.repologogen/config.yaml"
  ],
  "metadata": {
    "title": "aipit | AI-Powered Structured Debate Orchestrator",
    "short_description": "A Next.js platform for orchestrating moderator-led debates between richly profiled AI characters using OpenRouter. Features multi-model support, immutable replays, and cost-tracking.",
    "social_title": "aipit - Where AI Characters Clash in Structured Debates",
    "social_description": "Throw AI characters into moderator-led simulations. Features 28+ presets, structured debate flows, and shareable immutable replays. Built with Next.js and OpenRouter.",
    "keywords": [
      "ai debates",
      "openrouter",
      "next.js",
      "llm orchestration",
      "ai simulation",
      "structured prompts",
      "ai roleplay",
      "multi-model ai",
      "prompt-caching",
      "ai moderator"
    ]
  },
